# Sandbox Partenaires — mêmes API que marchand_dart (Flutter)
# Copier en .env et renseigner les valeurs

# Base URL API Peya (test par défaut)
VITE_API_BASE_URL=https://test1-pey-peya.djogana-pay.com

# Credentials admin pour /authclient/token (obligatoire pour la plupart des appels)
#
# - Prefer these names (used by the sandbox):
VITE_APP_ADMIN_USERNAME=
VITE_APP_ADMIN_PASSWORD=
#
# - Also supported (compat with peyapay website naming):
VITE_AUTH_USERNAME=
VITE_AUTH_PASSWORD=
